# ═══════════════════════════════════════════════════════════════
# DISSMODEL PLATFORM - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# ───────────────────────────────────────────────────────────────
# MinIO Storage (S3-compatible)
# ───────────────────────────────────────────────────────────────
MINIO_ROOT_USER=inpe_admin
MINIO_ROOT_PASSWORD=inpe_secret_2024
MINIO_ENDPOINT=minio:9000

# ───────────────────────────────────────────────────────────────
# Redis Queue
# ───────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ───────────────────────────────────────────────────────────────
# DisSModel Configuration
# ───────────────────────────────────────────────────────────────
DISSMODEL_LOG_LEVEL=INFO
DISSMODEL_CLOUD=false
DISSMODEL_MAX_STEPS=10000
DISSMODEL_TIMEOUT=3600

# ───────────────────────────────────────────────────────────────
# API Configuration
# ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_DEBUG=false

# ───────────────────────────────────────────────────────────────
# Jupyter Configuration
# ───────────────────────────────────────────────────────────────
JUPYTER_PORT=8888
JUPYTER_TOKEN=
JUPYTER_PASSWORD=

# ───────────────────────────────────────────────────────────────
# Worker Configuration
# ───────────────────────────────────────────────────────────────
WORKER_QUEUE=dissmodel_jobs
WORKER_CONCURRENCY=4
WORKER_ID=worker-1