
# ═══════════════════════════════════════════════════════════════
# DISSMODEL PLATFORM - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# ───────────────────────────────────────────────────────────────
# MinIO Storage (S3-compatible)
# ───────────────────────────────────────────────────────────────
MINIO_ROOT_USER=admin_xxxxxxxxxxxx
MINIO_ROOT_PASSWORD=pass_xxxxxxxxxxxxxxxxxxxxxxxx
MINIO_ENDPOINT=minio.local.xxxxxx:9000

# ───────────────────────────────────────────────────────────────
# Redis Queue
# ───────────────────────────────────────────────────────────────
REDIS_HOST=redis.cluster.xxxxxxxx
REDIS_PORT=xxxx
REDIS_PASSWORD=red_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ───────────────────────────────────────────────────────────────
# DisSModel Configuration
# ───────────────────────────────────────────────────────────────
DISSMODEL_LOG_LEVEL=DEBUG
DISSMODEL_CLOUD=true
DISSMODEL_MAX_STEPS=xxxxx
DISSMODEL_TIMEOUT=xxxx

# ───────────────────────────────────────────────────────────────
# API Configuration
# ───────────────────────────────────────────────────────────────
API_HOST=xxx.xxx.xxx.xxx
API_PORT=xxxx
API_WORKERS=xx
API_DEBUG=false

# ───────────────────────────────────────────────────────────────
# Jupyter Configuration
# ───────────────────────────────────────────────────────────────
JUPYTER_PORT=xxxx
JUPYTER_TOKEN=tok_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JUPYTER_PASSWORD=hash_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ───────────────────────────────────────────────────────────────
# Worker Configuration
# ───────────────────────────────────────────────────────────────
WORKER_QUEUE=queue_xxxxxxxxxxxx
WORKER_CONCURRENCY=xx
WORKER_ID=worker_node_xxxxxxxx

# ───────────────────────────────────────────────────────────────
# model configs
# ───────────────────────────────────────────────────────────────
CONFIGS_REPO=https://github.com/xxxxxxxxxxxx/xxxxxxxxxxxx.git
CONFIGS_BRANCH=branch_xxxx
CONFIGS_SYNC_INTERVAL=xxxx
